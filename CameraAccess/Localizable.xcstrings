  "strings" : {
    "%@ (%@) API Key" : {
      "comment" : "The title of the section that lists the API Key for a specific Alibaba provider and its corresponding endpoint. The first argument is the name of the Alibaba provider. The second argument is the name of the Alibaba endpoint.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ (%2$@) API Key"
          }
        }
      }
    },
    "%@ → %@" : {
      "comment" : "A label displaying the source and target language flags, followed by the timestamp of the translation.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ → %2$@"
          }
        }
      }
    },
    "%@ API Key" : {
      "comment" : "The title of the section that lists the API key for a specific provider. The placeholder is replaced with the name of the provider.",
      "isCommentAutoGenerated" : true
    },
    "%lld" : {
      "comment" : "A label displaying the user's health score. The text inside the label is dynamically updated based on the user's health score.",
      "isCommentAutoGenerated" : true
    },
    "%lld 条消息" : {
      "comment" : "A label displaying the number of messages in a conversation. The argument is the number of messages in the conversation.",
      "isCommentAutoGenerated" : true
    },
    "%lld." : {
      "comment" : "A numbered list item for a nutrition suggestion. The number is the index of the suggestion in the list (starting at 1).",
      "isCommentAutoGenerated" : true
    },
